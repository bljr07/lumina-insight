{
  "manifest_version": 3,
  "name": "Lumina Insight",
  "version": "1.0.0",
  "description": "A privacy-first browser extension that monitors student learning states using on-device AI.",

  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "permissions": [
    "storage",
    "activeTab",
    "offscreen",
    "idle",
    "sidePanel"
  ]
}
