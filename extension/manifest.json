{
  "manifest_version": 3,
  "name": "Lumina Insight",
  "version": "1.0.0",
  "description": "A privacy-first browser extension that monitors student learning states using on-device AI.",

  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "permissions": [
    "storage",
    "activeTab",
    "offscreen",
    "idle",
    "sidePanel"
  ]
}
