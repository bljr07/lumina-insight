{
  "manifest_version": 3,
  "name": "Lumina Insight",
  "version": "1.0.0",
  "description": "A browser extension built with Manifest V3.",

  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"]
    }
  ],
  "permissions": [
    "storage",
    "activeTab"
  ]
}
